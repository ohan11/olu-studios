<style>
  .site-footer {
    background: var(--hot-pink);
    color: #fff;
    margin-top: 0;
  }

  .sky-transition {
    height: 160px;
    background: linear-gradient(to bottom, #ffffff 0%, #ffb3c4 60%, #FF3160 100%);
    position: relative;
    overflow: hidden;
  }

  /* Pixel art clouds — box-shadow pixel technique
     Shape (all clouds):
       . . # # # . .
       . # # # # # .
       # # # # # # #
  */
  .cloud {
    position: absolute;
    pointer-events: none;
  }

  .cloud::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    background: transparent;
  }

  /* Cloud 1 — small, P=8px, top-left */
  .cloud-1 { top: 22px; left: 6%; }
  .cloud-1::before {
    width: 8px; height: 8px;
    box-shadow:
      16px 0    0 0 rgba(255,255,255,0.7),
      24px 0    0 0 rgba(255,255,255,0.7),
      32px 0    0 0 rgba(255,255,255,0.7),
      8px  8px  0 0 rgba(255,255,255,0.7),
      16px 8px  0 0 rgba(255,255,255,0.7),
      24px 8px  0 0 rgba(255,255,255,0.7),
      32px 8px  0 0 rgba(255,255,255,0.7),
      40px 8px  0 0 rgba(255,255,255,0.7),
      0    16px 0 0 rgba(255,255,255,0.7),
      8px  16px 0 0 rgba(255,255,255,0.7),
      16px 16px 0 0 rgba(255,255,255,0.7),
      24px 16px 0 0 rgba(255,255,255,0.7),
      32px 16px 0 0 rgba(255,255,255,0.7),
      40px 16px 0 0 rgba(255,255,255,0.7),
      48px 16px 0 0 rgba(255,255,255,0.7);
  }

  /* Cloud 2 — large, P=14px, center */
  .cloud-2 { top: 45px; left: 32%; }
  .cloud-2::before {
    width: 14px; height: 14px;
    box-shadow:
      28px 0    0 0 rgba(255,255,255,0.65),
      42px 0    0 0 rgba(255,255,255,0.65),
      56px 0    0 0 rgba(255,255,255,0.65),
      14px 14px 0 0 rgba(255,255,255,0.65),
      28px 14px 0 0 rgba(255,255,255,0.65),
      42px 14px 0 0 rgba(255,255,255,0.65),
      56px 14px 0 0 rgba(255,255,255,0.65),
      70px 14px 0 0 rgba(255,255,255,0.65),
      0    28px 0 0 rgba(255,255,255,0.65),
      14px 28px 0 0 rgba(255,255,255,0.65),
      28px 28px 0 0 rgba(255,255,255,0.65),
      42px 28px 0 0 rgba(255,255,255,0.65),
      56px 28px 0 0 rgba(255,255,255,0.65),
      70px 28px 0 0 rgba(255,255,255,0.65),
      84px 28px 0 0 rgba(255,255,255,0.65);
  }

  /* Cloud 3 — medium, P=10px, top-right */
  .cloud-3 { top: 18px; right: 10%; }
  .cloud-3::before {
    width: 10px; height: 10px;
    box-shadow:
      20px 0    0 0 rgba(255,255,255,0.7),
      30px 0    0 0 rgba(255,255,255,0.7),
      40px 0    0 0 rgba(255,255,255,0.7),
      10px 10px 0 0 rgba(255,255,255,0.7),
      20px 10px 0 0 rgba(255,255,255,0.7),
      30px 10px 0 0 rgba(255,255,255,0.7),
      40px 10px 0 0 rgba(255,255,255,0.7),
      50px 10px 0 0 rgba(255,255,255,0.7),
      0    20px 0 0 rgba(255,255,255,0.7),
      10px 20px 0 0 rgba(255,255,255,0.7),
      20px 20px 0 0 rgba(255,255,255,0.7),
      30px 20px 0 0 rgba(255,255,255,0.7),
      40px 20px 0 0 rgba(255,255,255,0.7),
      50px 20px 0 0 rgba(255,255,255,0.7),
      60px 20px 0 0 rgba(255,255,255,0.7);
  }

  /* Cloud 4 — small, P=6px, lower center-right */
  .cloud-4 { top: 85px; right: 28%; }
  .cloud-4::before {
    width: 6px; height: 6px;
    box-shadow:
      12px 0    0 0 rgba(255,255,255,0.55),
      18px 0    0 0 rgba(255,255,255,0.55),
      24px 0    0 0 rgba(255,255,255,0.55),
      6px  6px  0 0 rgba(255,255,255,0.55),
      12px 6px  0 0 rgba(255,255,255,0.55),
      18px 6px  0 0 rgba(255,255,255,0.55),
      24px 6px  0 0 rgba(255,255,255,0.55),
      30px 6px  0 0 rgba(255,255,255,0.55),
      0    12px 0 0 rgba(255,255,255,0.55),
      6px  12px 0 0 rgba(255,255,255,0.55),
      12px 12px 0 0 rgba(255,255,255,0.55),
      18px 12px 0 0 rgba(255,255,255,0.55),
      24px 12px 0 0 rgba(255,255,255,0.55),
      30px 12px 0 0 rgba(255,255,255,0.55),
      36px 12px 0 0 rgba(255,255,255,0.55);
  }

  .footer-body {
    padding: 16px 24px 40px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
    width: 100%;
    gap: 8px;
    padding-bottom: 28px;
  }

  .footer-middle {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .plane-text {
    font-family: 'VT323', monospace;
    font-size: 26px;
    color: #fff;
    text-align: center;
    margin: 0 0 6px;
    opacity: 0.9;
  }

  .footer-middle pre {
    font-family: monospace;
    font-size: 18px;
    color: #fff;
    text-align: center;
    line-height: 1.6;
    opacity: 0.9;
    white-space: pre;
    margin: 0;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 16px;
    justify-self: start;
  }

  .policy-links {
    display: flex;
    flex-direction: row;
    gap: 24px;
  }

  .policy-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .policy-links a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
    text-decoration: none;
    transition: opacity 0.2s ease;
    letter-spacing: 0.04em;
  }

  .policy-links a:hover {
    color: #fff;
    opacity: 1;
  }

  /* Socials */
  .social-list {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .social-link {
    color: #fff;
    display: flex;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .social-link:hover {
    opacity: 0.75;
    color: #fff;
    transform: translateY(-2px);
  }

  /* Tagline */
  .footer-tagline {
    font-family: 'East Sea Dokdo', sans-serif;
    font-size: 24px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 10px;
  }

  .email-col {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-self: end;
    width: 85%;
  }

  /* Email form */
  .email-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
    min-width: 200px;
  }

  .email-input {
    padding: 11px 16px;
    font-size: 14px;
    border: none;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
    outline: none;
    font-family: inherit;
    width: 100%;
  }

  .email-input::placeholder {
    color: rgba(255, 255, 255, 0.65);
  }

  .email-input:focus {
    background: rgba(255, 255, 255, 0.32);
  }

  .email-btn {
    padding: 11px 20px;
    background: #fff;
    color: var(--hot-pink);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-family: inherit;
    transition: opacity 0.2s ease;
  }

  .email-btn:hover {
    opacity: 0.88;
  }

  .footer-copy {
    font-size: 12px;
    opacity: 0.55;
    margin: 0;
    text-align: left;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .footer-middle {
      justify-content: flex-start;
    }

    .email-col {
      align-items: stretch;
    }
  }
</style>
