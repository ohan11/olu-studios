---
interface Props {
  id: string;
  name: string;
  description?: string;
  price: number;
  currency?: string;
  image: string;
  stripePriceId?: string;
  available?: boolean;
}

const {
  name,
  description,
  price,
  currency = 'USD',
  image,
  stripePriceId,
  available = true,
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL || '/';
const imgSrc = image.startsWith('http') ? image : `${baseUrl.replace(/\/$/, '')}${image}`;
const formattedPrice = new Intl.NumberFormat('en-US', { style: 'currency', currency }).format(price);
const canBuy = available && !!stripePriceId;

const cartData = JSON.stringify({ priceId: stripePriceId, name, price, currency, imgSrc });
---

<div class="product-card">
  <div class="product-image">
    <img src={imgSrc} alt={name} />
  </div>
  <div class="product-info">
    <h3 class="product-name">{name}</h3>
    {description && <p class="product-description">{description}</p>}
    <div class="product-footer">
      <span class="product-price">{formattedPrice}</span>
      {canBuy ? (
        <button class="add-to-cart-btn" data-product={cartData}>add to cart</button>
      ) : available ? (
        <span class="coming-soon">coming soon</span>
      ) : (
        <span class="sold-out">sold out</span>
      )}
    </div>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.add-to-cart-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const product = JSON.parse(btn.dataset.product!);
      document.dispatchEvent(new CustomEvent('cart:add', { detail: product }));
    });
  });
</script>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    color: var(--text-dark);
  }

  .product-image {
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #f5f0f0;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .product-card:hover .product-image img {
    transform: scale(1.04);
  }

  .product-info {
    padding: 14px 0 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .product-name {
    font-family: 'VT323', monospace;
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--text-dark);
    text-transform: lowercase;
    margin: 0;
  }

  .product-description {
    font-size: 13px;
    color: #888;
    margin: 0;
    line-height: 1.5;
  }

  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 8px;
  }

  .product-price {
    font-family: 'VT323', monospace;
    font-size: 1.1rem;
    color: var(--text-dark);
  }

  .add-to-cart-btn {
    display: inline-block;
    padding: 6px 20px;
    background: var(--hot-pink);
    color: #fff;
    font-family: 'VT323', monospace;
    font-size: 1rem;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .add-to-cart-btn:hover {
    opacity: 0.85;
  }

  .sold-out,
  .coming-soon {
    font-family: 'VT323', monospace;
    font-size: 1rem;
    color: #aaa;
  }
</style>
