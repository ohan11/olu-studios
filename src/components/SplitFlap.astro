---
interface Props {
  texts: string[];
  delay?: number;
  interval?: number; // ms to display each phrase before switching
}
const { texts, delay = 400, interval = 4000 } = Astro.props;
const maxLen = Math.max(...texts.map(t => t.length));
const id = `sf-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="splitflap-board" id={id}
  data-texts={JSON.stringify(texts)}
  data-delay={delay}
  data-interval={interval}>
  {Array.from({ length: maxLen }).map((_, i) => (
    <div class="sf-cell" data-index={i}>
      <div class="sf-inner">
        <div class="sf-face sf-front"><span>&nbsp;</span></div>
        <div class="sf-face sf-back"><span>&nbsp;</span></div>
      </div>
    </div>
  ))}
</div>

<style>
  .splitflap-board {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
    padding: 16px 24px;
    border-radius: 6px;
  }

  .sf-cell {
    width: 26px;
    height: 34px;
    perspective: 200px;
    position: relative;
  }

  .sf-inner {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    background: #f9d0d0;
    border-radius: 3px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.5), 0 1px 3px rgba(0,0,0,0.15);
    overflow: hidden;
  }

  /* horizontal split line */
  .sf-inner::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 1px;
    background: rgba(0,0,0,0.06);
    z-index: 10;
    pointer-events: none;
  }

  .sf-face {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'VT323', monospace;
    font-size: 1.5rem;
    color: #3a1a1a;
    text-shadow: none;
    backface-visibility: hidden;
    border-radius: 3px;
    background: #f9d0d0;
  }

  .sf-front { transform: rotateX(0deg); }
  .sf-back  { transform: rotateX(180deg); }

  .sf-cell.flipping .sf-inner {
    animation: sfFlip 0.08s ease-in-out forwards;
  }

  @keyframes sfFlip {
    0%   { transform: rotateX(0deg); }
    50%  { transform: rotateX(-90deg); }
    100% { transform: rotateX(0deg); }
  }
</style>

<script>
  const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.!?/- ';

  function randomChar(): string {
    return CHARS[Math.floor(Math.random() * (CHARS.length - 1))]; // exclude space from randoms
  }

  function padCenter(text: string, length: number): string {
    const total = length - text.length;
    const left = Math.floor(total / 2);
    const right = total - left;
    return ' '.repeat(left) + text + ' '.repeat(right);
  }

  function animateCell(
    cell: HTMLElement,
    targetChar: string,
    cycles: number,
    cycleInterval: number
  ): Promise<void> {
    return new Promise(resolve => {
      const inner = cell.querySelector('.sf-inner') as HTMLElement;
      const front = cell.querySelector('.sf-front span') as HTMLElement;
      let count = 0;

      function flip(char: string) {
        front.textContent = char === ' ' ? '\u00A0' : char;
        inner.classList.remove('flipping');
        void inner.offsetWidth;
        inner.classList.add('flipping');
      }

      const timer = setInterval(() => {
        count++;
        if (count >= cycles) {
          clearInterval(timer);
          flip(targetChar);
          setTimeout(resolve, cycleInterval);
        } else {
          flip(randomChar());
        }
      }, cycleInterval);
    });
  }

  function animateBoard(cells: HTMLElement[], targetText: string): Promise<void> {
    const promises = cells.map((cell, i) => {
      const targetChar = targetText[i]?.toUpperCase() ?? ' ';
      if (targetChar === ' ') {
        // blank it immediately with no animation
        const front = cell.querySelector('.sf-front span') as HTMLElement;
        front.textContent = '\u00A0';
        return Promise.resolve();
      }
      const stagger = i * 35;
      const cycles = 5 + Math.floor(Math.random() * 5);
      return new Promise<void>(resolve => {
        setTimeout(() => animateCell(cell, targetChar, cycles, 75).then(resolve), stagger);
      });
    });
    return Promise.all(promises).then(() => {});
  }

  document.querySelectorAll<HTMLElement>('.splitflap-board').forEach(board => {
    const texts: string[] = JSON.parse(board.dataset.texts ?? '[]');
    const delay = parseInt(board.dataset.delay ?? '400', 10);
    const interval = parseInt(board.dataset.interval ?? '4000', 10);
    const cells = Array.from(board.querySelectorAll<HTMLElement>('.sf-cell'));
    const maxLen = cells.length;

    let current = 0;

    async function showNext() {
      const padded = padCenter(texts[current].toUpperCase(), maxLen);
      await animateBoard(cells, padded);
      current = (current + 1) % texts.length;
      setTimeout(showNext, interval);
    }

    setTimeout(showNext, delay);
  });
</script>
