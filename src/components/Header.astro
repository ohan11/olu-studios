---
// Header component with logo, navigation dropdown, and cart
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="site-header">
  <div class="header-content">
    <nav class="header-left">
      <a href={`${base}/shop`} class="nav-link">shop</a>
      <a href={`${base}/work`} class="nav-link">work</a>
      <a href={`${base}/about`} class="nav-link">about</a>
    </nav>

    <div class="header-center">
      <a href={`${base}/`} class="logo">
        <img src={`${base}/images/logo.png`} alt="SLU" />
      </a>
    </div>

    <div class="header-right">
      <button class="cart-btn" id="cart-btn" aria-label="Open cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="cart-count" id="cart-count" style="display:none">0</span>
      </button>
    </div>

    <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobile-nav">
    <a href={`${base}/shop`}>shop</a>
    <a href={`${base}/work`}>work</a>
    <a href={`${base}/about`}>about</a>
  </nav>
</header>

<style>
  .site-header {
    background: var(--bg-white);
    border-bottom: 1px solid #e5e5e5;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .header-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 20px 16px 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }
  
  .header-left {
    display: flex;
    align-items: center;
    gap: 24px;
    flex: 1;
    justify-content: flex-start;
  }
  
  .header-center {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }
  
  .logo {
    display: block;
    text-decoration: none;
  }
  
  .logo img {
    height: 48px;
    width: auto;
    display: block;
  }
  
  .nav-link {
    font-size: 14px;
    text-transform: lowercase;
    color: var(--text-dark);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .nav-link:hover {
    color: var(--hot-pink);
  }
  
  
  .header-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .cart-btn {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-dark);
    padding: 4px;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .cart-btn:hover {
    color: var(--hot-pink);
  }

  .cart-count {
    position: absolute;
    top: -4px;
    right: -6px;
    background: var(--hot-pink);
    color: #fff;
    font-family: 'VT323', monospace;
    font-size: 0.75rem;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  
  .mobile-menu-btn span {
    width: 24px;
    height: 2px;
    background: var(--text-dark);
    transition: all 0.3s ease;
  }
  
  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 16px;
    padding: 20px;
    background: var(--bg-white);
    border-top: 1px solid #e5e5e5;
  }
  
  .mobile-nav.active {
    display: flex;
  }
  
  .mobile-nav a {
    font-size: 16px;
    text-transform: lowercase;
    color: var(--text-dark);
    text-decoration: none;
    padding: 8px 0;
  }
  
  .mobile-nav a:hover {
    color: var(--hot-pink);
  }
  
  @media (max-width: 768px) {
    .header-left {
      display: none;
    }
    
    .mobile-menu-btn {
      display: flex;
    }
    
    .header-center {
      flex: 1;
      justify-content: center;
    }
    
    .logo img {
      height: 38px;
    }
  }
</style>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileNav = document.getElementById('mobile-nav');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileNav?.classList.toggle('active');
    mobileMenuBtn?.classList.toggle('active');
  });

  const cartBtn = document.getElementById('cart-btn');
  const cartCount = document.getElementById('cart-count');

  cartBtn?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('cart:open'));
  });

  // Initialise count from localStorage on page load
  function updateCount() {
    try {
      const cart = JSON.parse(localStorage.getItem('olu-cart') || '[]');
      const count = cart.reduce((sum: number, i: any) => sum + i.quantity, 0);
      if (cartCount) {
        cartCount.textContent = String(count);
        cartCount.style.display = count > 0 ? 'flex' : 'none';
      }
    } catch {}
  }

  updateCount();

  document.addEventListener('cart:updated', (e: Event) => {
    const { count } = (e as CustomEvent).detail;
    if (cartCount) {
      cartCount.textContent = String(count);
      cartCount.style.display = count > 0 ? 'flex' : 'none';
    }
  });
  
</script>
