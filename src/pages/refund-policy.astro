---
import Layout from '../layouts/Layout.astro';
---

<Layout title="refund policy - olu studios">
  <div class="policy-page">
    <div class="container">
      <h1>Refund Policy</h1>
      <div class="policy-body">
        <p>Last updated: April 2026</p>
        <p>We want you to be completely satisfied with your purchase. If you are not satisfied for any reason, please contact us within 14 days of receiving your order.</p>
        <h2>Eligibility</h2>
        <p>To be eligible for a return, items must be unused and in the same condition that you received them. Original and limited edition prints are final sale.</p>
        <h2>Process</h2>
        <p>To initiate a return, please contact us with your order number and reason for return. Once your return is received and inspected, we will notify you of the approval or rejection of your refund.</p>
        <h2>Refunds</h2>
        <p>If approved, your refund will be processed and a credit will automatically be applied to your original method of payment within 7–10 business days.</p>
        <h2>Questions</h2>
        <p>If you have any questions about our refund policy, please reach out via the contact page.</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .policy-page {
    padding: 60px 0 80px;
    min-height: calc(100vh - 200px);
  }

  h1 {
    font-size: 42px;
    font-weight: 700;
    margin-bottom: 40px;
    color: var(--text-dark);
  }

  .policy-body {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  h2 {
    font-size: 18px;
    font-weight: 600;
    margin-top: 12px;
    color: var(--text-dark);
  }

  p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-light);
  }
</style>
