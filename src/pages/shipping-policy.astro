---
import Layout from '../layouts/Layout.astro';
---

<Layout title="shipping policy - olu studios">
  <div class="policy-page">
    <div class="container">
      <h1>SHIPPING POLICY</h1>
      <p>All items are hand packaged by me <333</p>
      <br>
      <br>
      <p>Please allow 1-2 weeks for orders. Currently only shipping within the US.</p>
    </div>
  </div>
</Layout>

<style>
  .policy-page {
    padding: 96px 0 96px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .container {
    text-align: center;
    max-width: 600px;
  }

  h1 {
    font-family: 'East Sea Dokdo', sans-serif;
    font-size: clamp(2.2rem, 10vw, 96px);
    font-weight: 900;
    color: var(--hot-pink);
    margin-bottom: 32px;
    letter-spacing: 0.08em;
    line-height: 1;
    white-space: nowrap;
  }

  p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-light);
    text-align: left;
  }
</style>
