---
import Layout from '../layouts/Layout.astro';
import ShopifyCollection from '../components/ShopifyCollection.astro';
import SplitFlap from '../components/SplitFlap.astro';

const storeDomain = '8ygcdj-p0.myshopify.com';
const baseUrl = import.meta.env.BASE_URL || '/';
const allItems = await import('../data/portfolio/items.json').then(m => m.default);
const showcase = allItems.filter((item: { featured?: boolean }) => item.featured);
const homeData = await import('../data/home.json').then(m => m.default).catch(() => ({
  backgroundImage: '/images/stamps.jpeg',
  title: 'Olu',
  about: {
    image: '/images/profile.jpg',
    text: 'Welcome to Olu Studios. I\'m an artist creating unique pieces that blend traditional and contemporary styles.'
  }
}));
const bgUrl = homeData.backgroundImage.startsWith('http') 
  ? homeData.backgroundImage 
  : `${baseUrl.replace(/\/$/, '')}${homeData.backgroundImage}`;

// Home collection configuration
const homeCollectionId = '325811273900';

// Custom styling for Home collection (pink/coral theme)
const homeOptions = {
  product: {
    styles: {
      product: {
        '@media (min-width: 601px)': {
          'max-width': 'calc(33.33333% - 30px)',
          'margin-left': '30px',
          'margin-bottom': '50px',
          'width': 'calc(33.33333% - 30px)'
        },
        'text-align': 'left',
        img: {
          height: 'calc(100% - 15px)',
          position: 'absolute',
          left: '0',
          right: '0',
          top: '0'
        },
        imgWrapper: {
          'padding-top': 'calc(75% + 15px)',
          position: 'relative',
          height: '0'
        }
      },
      button: {
        color: '#793939',
        'background-color': '#ed9494',
        ':hover': {
          color: '#793939',
          'background-color': '#d58585'
        },
        ':focus': {
          'background-color': '#d58585'
        },
        'border-radius': '20px',
        'padding-left': '47px',
        'padding-right': '47px'
      }
    },
    buttonDestination: 'modal',
    contents: {
      button: false,
      options: false
    },
    isButton: true,
    text: {
      button: 'View '
    }
  },
  productSet: {
    styles: {
      products: {
        '@media (min-width: 601px)': {
          'margin-left': '-30px'
        }
      }
    }
  },
  modalProduct: {
    contents: {
      img: false,
      imgWithCarousel: true,
      button: false,
      buttonWithQuantity: true
    },
    styles: {
      product: {
        '@media (min-width: 601px)': {
          'max-width': '100%',
          'margin-left': '0px',
          'margin-bottom': '0px'
        }
      },
      button: {
        color: '#793939',
        'background-color': '#ed9494',
        ':hover': {
          color: '#793939',
          'background-color': '#d58585'
        },
        ':focus': {
          'background-color': '#d58585'
        },
        'border-radius': '20px',
        'padding-left': '47px',
        'padding-right': '47px'
      }
    },
    text: {
      button: 'Add to cart'
    }
  },
  option: {},
  cart: {
    styles: {
      button: {
        color: '#793939',
        'background-color': '#ed9494',
        ':hover': {
          color: '#793939',
          'background-color': '#d58585'
        },
        ':focus': {
          'background-color': '#d58585'
        },
        'border-radius': '20px'
      }
    },
    text: {
      total: 'Subtotal',
      button: 'Checkout'
    }
  },
  toggle: {
    styles: {
      toggle: {
        'background-color': '#ed9494',
        ':hover': {
          'background-color': '#d58585'
        },
        ':focus': {
          'background-color': '#d58585'
        }
      },
      count: {
        color: '#793939',
        ':hover': {
          color: '#793939'
        }
      },
      iconPath: {
        fill: '#793939'
      }
    }
  }
};
---

<Layout title="olu studios">
  <div class="home-page">
    <!-- Section Label -->
    <div class="section-intro">
      <SplitFlap texts={[" NOW BOARDING OLU AIRLINES ", "GO TO GATE 333"]} delay={400} interval={2000} />
    </div>

    <!-- Hero Section with Background Image -->
    <section class="hero-section">
      <div class="hero-background">
        <img src={bgUrl} alt="" class="hero-bg-image" />
      </div>
    </section>

    <!-- Section Label -->
    <p class="showcase-label">hi i'm olu...this is what i've been working on...</p>

    <!-- Image Grid Section -->
    <section class="grid-section">
      <div class="image-grid">
        {showcase.map((item) => {
          const imgSrc = item.image.startsWith('http')
            ? item.image
            : `${baseUrl.replace(/\/$/, '')}${item.image}`;
          return (
            <a href={item.link} class="grid-item">
              <img src={imgSrc} alt={item.title} />
              <div class="grid-item-overlay">
                <span class="grid-item-title">{item.title}</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Prints Banner -->
    <section class="prints-banner">
      <img src={`${baseUrl.replace(/\/$/, '')}/images/la-postcards.jpeg`} alt="" class="prints-banner-img" />
      <div class="prints-banner-overlay">
        <p class="prints-banner-text">shop fine art prints</p>
        <a href={`${baseUrl.replace(/\/$/, '')}/shop/prints`} class="prints-banner-btn">Shop Now</a>
      </div>
    </section>

    <!-- Visa Section -->
    <section class="visa-section">
      <div class="visa-overlay">
        <img src={`${baseUrl.replace(/\/$/, '')}/images/visapage.png`} alt="" class="visa-image" />
        <img src={`${baseUrl.replace(/\/$/, '')}/images/photostrip.jpg`} alt="" class="photostrip" />
        <div class="visa-text">
            <p>
              Olivia Lu is an artist based in NYC.<br />
            </p>
        </div>
        <a href={`${baseUrl.replace(/\/$/, '')}/about`} class="visa-contact-btn">Get in touch</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .home-page {
    min-height: 100vh;
  }

  .hero-section {
    width: 100%;
    height: 60vh;
    min-height: 400px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  /* Prints Banner */
  .prints-banner {
    position: relative;
    height: 340px;
    overflow: hidden;
  }

  .prints-banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .prints-banner-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
  }

  .prints-banner-text {
    font-size: 2.2rem;
    font-weight: 300;
    font-style: italic;
    color: #fff;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    margin: 0;
  }

  .prints-banner-btn {
    display: inline-block;
    padding: 12px 36px;
    border: 2px solid #fff;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .prints-banner-btn:hover {
    background: #fff;
    color: #1a1a1a;
  }

  .visa-section {
    padding: 40px 24px;
    display: flex;
    justify-content: center;
    background: var(--bg-white);
  }

  .visa-overlay {
    position: relative;
    width: min(780px, 100%);
    filter: drop-shadow(0 8px 32px rgba(0, 0, 0, 0.15));
  }

  .visa-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .photostrip {
    position: absolute;
    top: 50%;
    left: 25%;
    transform: translate(-50%, -50%) rotate(-4deg);
    height: 75%;
    width: auto;
    object-fit: contain;
  }

  .visa-text {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: 10%;
    transform: translate(-4%, -10%) rotate(-6deg);
  }

  .visa-text p {
    font-family: 'Reenie Beanie', cursive;
    font-size: 1.6rem;
    font-weight: 400;
    color: #2a2060;
    text-align: left;
    line-height: 1.5;
    margin: 0 0 16px;
    max-width: 55%;
  }

  .visa-contact-btn {
    position: absolute;
    bottom: 22%;
    left: 68%;
    font-family: 'Reenie Beanie', cursive;
    font-size: 1.1rem;
    color: #2a2060;
    border: 1.5px solid #2a2060;
    padding: 4px 16px;
    text-decoration: none;
    transform: rotate(4deg);
    transition: background 0.2s ease, color 0.2s ease;
  }

  .visa-contact-btn:hover {
    background: #2a2060;
    color: #fff;
  }

  .hero-bg-image {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }


  .showcase-label {
    font-family: 'VT323', monospace;
    font-size: 1.6rem;
    color: var(--text-dark);
    text-align: center;
    padding: 32px 24px 0;
    margin: 0;
  }

  .section-intro {
    display: flex;
    justify-content: center;
    padding: 12px 24px 0;
    margin: 0;
  }

  /* Image Grid Section */
  .grid-section {
    padding: 32px 0;
  }

  .image-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .grid-item {
    position: relative;
    display: block;
    aspect-ratio: 4 / 6;
    overflow: hidden;
    text-decoration: none;
  }

  .grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .grid-item:hover img {
    transform: scale(1.04);
  }

  .grid-item-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .grid-item:hover .grid-item-overlay {
    opacity: 1;
  }

  .grid-item-title {
    color: #fff;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }



  @media (max-width: 768px) {
    .hero-section {
      height: 20vh;
      min-height: 150px;
    }

    .grid-section {
      padding: 40px 0;
    }

    .visa-section {
      padding: 48px 16px;
    }

    .visa-text p {
      font-size: 0.75rem;
      line-height: 1.4;
      margin: 0 0 8px;
    }

    .visa-contact-btn {
      font-size: 0.7rem;
      padding: 3px 10px;
      bottom: 18%;
    }

    .image-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
      padding: 0 16px;
    }

    .grid-item-title {
      font-size: 16px;
    }

  }
</style>
