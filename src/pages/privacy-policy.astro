---
import Layout from '../layouts/Layout.astro';
---

<Layout title="privacy policy - olu studios">
  <div class="policy-page">
    <div class="container">
      <h1>Privacy Policy</h1>
      <div class="policy-body">
        <p>Last updated: April 2026</p>
        <p>Your privacy is important to us. This policy explains what information we collect, how we use it, and the choices you have.</p>
        <h2>Information We Collect</h2>
        <p>We collect information you provide directly, such as your name, email address, and shipping address when you place an order or sign up for our newsletter.</p>
        <h2>How We Use It</h2>
        <p>We use your information to process orders, send shipping updates, and — if you've opted in — send occasional emails about new work and releases. We do not sell your data to third parties.</p>
        <h2>Cookies</h2>
        <p>Our site uses cookies to improve your browsing experience and to help our shop function. You can disable cookies in your browser settings at any time.</p>
        <h2>Third Parties</h2>
        <p>We use Shopify to process payments. Their privacy policy governs any data shared during checkout. We may also use analytics tools to understand how visitors use the site.</p>
        <h2>Contact</h2>
        <p>If you have questions about this policy, please reach out via the contact page.</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .policy-page {
    padding: 60px 0 80px;
    min-height: calc(100vh - 200px);
  }

  h1 {
    font-size: 42px;
    font-weight: 700;
    margin-bottom: 40px;
    color: var(--text-dark);
  }

  .policy-body {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  h2 {
    font-size: 18px;
    font-weight: 600;
    margin-top: 12px;
    color: var(--text-dark);
  }

  p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-light);
  }
</style>
