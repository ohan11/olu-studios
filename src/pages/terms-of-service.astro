---
import Layout from '../layouts/Layout.astro';
---

<Layout title="terms of service - olu studios">
  <div class="policy-page">
    <div class="container">
      <h1>Terms of Service</h1>
      <div class="policy-body">
        <p>Last updated: April 2026</p>
        <p>By using this website and purchasing from Olu Studios, you agree to the following terms.</p>
        <h2>Use of the Site</h2>
        <p>This site is for personal, non-commercial use. You may not reproduce, distribute, or create derivative works from any content on this site without explicit written permission.</p>
        <h2>Intellectual Property</h2>
        <p>All artwork, images, and content on this site are the sole property of Olu Studios. Purchasing a print does not transfer any intellectual property rights.</p>
        <h2>Orders & Pricing</h2>
        <p>We reserve the right to cancel any order at our discretion and will issue a full refund if we do so. Prices are subject to change without notice.</p>
        <h2>Limitation of Liability</h2>
        <p>Olu Studios is not liable for any indirect or consequential damages arising from your use of this site or purchase of products.</p>
        <h2>Changes to Terms</h2>
        <p>We may update these terms from time to time. Continued use of the site after any changes constitutes acceptance of the new terms.</p>
        <h2>Contact</h2>
        <p>Questions? Reach out via the contact page.</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .policy-page {
    padding: 60px 0 80px;
    min-height: calc(100vh - 200px);
  }

  h1 {
    font-size: 42px;
    font-weight: 700;
    margin-bottom: 40px;
    color: var(--text-dark);
  }

  .policy-body {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  h2 {
    font-size: 18px;
    font-weight: 600;
    margin-top: 12px;
    color: var(--text-dark);
  }

  p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-light);
  }
</style>
