---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ShopClosed from '../../components/ShopClosed.astro';
import shopConfig from '../../data/shop/config.json';

const allProducts = await import('../../data/shop/products.json').then(m => m.default);
const products = allProducts.filter((p: any) => p.tags.includes('prints'));
---

<Layout title="prints - olu studios">
  <div class="shop-page">
    <p class="page-label">prints</p>
    {shopConfig.shopOpen ? (
      <div class="product-grid">
        {products.map((product: any) => (
          <ProductCard {...product} />
        ))}
      </div>
    ) : (
      <ShopClosed returnDate={shopConfig.returnDate} />
    )}
  </div>
</Layout>

<style>
  .shop-page {
    padding: 40px 24px 100px;
    max-width: 1200px;
    margin: 0 auto;
    min-height: calc(100vh - 300px);
  }

  .page-label {
    font-family: 'VT323', monospace;
    font-size: 1.6rem;
    color: var(--text-dark);
    text-align: center;
    margin: 0 0 32px;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 24px;
  }

  @media (max-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 16px;
    }
  }
</style>
