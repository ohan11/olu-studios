---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ShopClosed from '../../components/ShopClosed.astro';
import shopConfig from '../../data/shop/config.json';
import type { ShopTag } from '../../data/shop/tags';
import { hasImage } from '../../lib/productUtils';

const allProducts = await import('../../data/shop/products.json').then(m => m.default);
const products = allProducts
  .filter((p: { tags: ShopTag[] }) => p.tags.includes('prints'))
  .filter((p: any) => hasImage(p))
  .sort((a: any, b: any) => (a.tier ?? 2) - (b.tier ?? 2));
---

<Layout title="prints - olu studios">
  <div class="shop-page">
    <p class="page-label">prints</p>
    {shopConfig.shopOpen ? (
      products.length > 0 ? (
        <div class="product-grid">
          {products.map((product: any) => (
            <ProductCard {...product} />
          ))}
        </div>
      ) : (
        <p class="empty">sorry, no prints currently available! :(</p>
      )
    ) : (
      <ShopClosed returnDate={shopConfig.returnDate} />
    )}
  </div>
</Layout>

<style>
  .shop-page {
    padding: 40px 24px 100px;
    max-width: 1200px;
    margin: 0 auto;
    min-height: calc(100vh - 300px);
  }

  .page-label {
    font-family: 'VT323', monospace;
    font-size: 1.6rem;
    color: var(--text-dark);
    text-align: center;
    margin: 0 0 32px;
  }

  .empty {
    font-family: 'VT323', monospace;
    font-size: 1.3rem;
    color: #888;
    text-align: center;
    padding: 60px 0;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 24px;
  }

  @media (max-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 16px;
    }
  }
</style>
