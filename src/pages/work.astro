---
import Layout from '../layouts/Layout.astro';
import ProtectedImage from '../components/ProtectedImage.astro';
import { getPortfolioItems } from '../lib/portfolio';

const portfolioItems = await getPortfolioItems();
const collections = await import('../data/portfolio/collections.json').then(m => m.default);
const baseUrl = import.meta.env.BASE_URL || '/';
---

<Layout title="work - olu studios">
  <div class="work-page">
    <div class="container">
      <h1 class="page-title">Work</h1>

      {collections.length > 0 && (
        <section class="collections-section">
          <div class="collections-grid">
            {collections.map((col) => {
              const imgSrc = col.thumbnail.startsWith('http')
                ? col.thumbnail
                : `${baseUrl.replace(/\/$/, '')}${col.thumbnail}`;
              return (
                <a href={`${baseUrl.replace(/\/$/, '')}/work/${col.id}`} class="collection-item">
                  <ProtectedImage src={imgSrc} alt={col.title} />
                  <div class="collection-overlay">
                    <span class="collection-title">{col.title}</span>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}

      {portfolioItems.length > 0 && (
        <section class="works-section">
          <p class="section-label">Works</p>
          <div class="work-grid">
            {portfolioItems.map((item) => (
              <div class="work-item">
                {item.images.map((image) => (
                  <ProtectedImage src={image} alt={item.title || 'Artwork'} />
                ))}
              </div>
            ))}
          </div>
        </section>
      )}

      {collections.length === 0 && portfolioItems.length === 0 && (
        <div class="no-work">
          <p>Work coming soon!</p>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .work-page {
    padding: 60px 0;
    min-height: calc(100vh - 200px);
  }

  .page-title {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 40px;
    color: var(--text-dark);
  }

  /* Collection blocks */
  .collections-section {
    margin-bottom: 60px;
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .collection-item {
    position: relative;
    display: block;
    aspect-ratio: 4 / 6;
    overflow: hidden;
    text-decoration: none;
  }

  .collection-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .collection-item:hover img {
    transform: scale(1.04);
  }

  .collection-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .collection-item:hover .collection-overlay {
    opacity: 1;
  }

  .collection-title {
    color: #fff;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Individual works section */
  .works-section {
    margin-top: 20px;
  }

  .section-label {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-light, #888);
    margin-bottom: 24px;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 32px;
  }

  .work-item {
    width: 100%;
  }

  .work-item img {
    width: 100%;
    height: auto;
    display: block;
  }

  .no-work {
    text-align: center;
    padding: 80px 20px;
    color: var(--text-light);
  }

  @media (max-width: 768px) {
    .work-page {
      padding: 40px 0;
    }

    .page-title {
      font-size: 36px;
      margin-bottom: 32px;
    }

    .collections-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .collection-title {
      font-size: 16px;
    }

    .work-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 20px;
    }
  }
</style>
